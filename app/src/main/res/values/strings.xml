    <string name="app_name">Echoes</string>
    <string name="welcome_kicker">Echoes</string>
    <string name="welcome_title">Create capsules for moments worth returning to.</string>
    <string name="welcome_subtitle">Save text and images, unlock them by time or place, and keep your archive available before cloud sync.</string>
    <string name="day_one_heading">Core experience</string>
    <string name="day_one_body">Create, archive, discover, unlock, favourite, comment on, and sync capsules while the local archive remains dependable on this device.</string>
    <string name="final_readiness_title">Privacy and sync</string>
    <string name="final_readiness_local_title">Your archive stays local first</string>
    <string name="final_readiness_local_body">Capsules are saved on this device first, so the archive stays usable even before cloud sync.</string>
    <string name="final_readiness_cloud_title">Firebase sync is optional</string>
    <string name="final_readiness_cloud_body">Sign in when you want to mirror your archive to your Firebase account.</string>
    <string name="final_readiness_device_title">Permissions are requested in context</string>
    <string name="final_readiness_device_body">Camera, image, location, and notifications are requested only when a feature needs them.</string>
    <string name="final_readiness_tests_title">Unlocks stay transparent</string>
    <string name="final_readiness_tests_body">Time and location locks show their status before and after a capsule opens.</string>
