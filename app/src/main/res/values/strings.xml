    <string name="welcome_title">Unlocks can now nudge you back.</string>
    <string name="welcome_subtitle">Future time capsules can schedule a local unlock notification, while validation and accessibility labels make the core screens safer to use.</string>
    <string name="day_one_heading">What works today</string>
    <string name="day_one_body">The app now moves through auth, create, archive, discovery, detail, Firestore sync, favourites, comments, consent-based location unlock, and local time-unlock notifications while keeping Room as the local base.</string>
